@startuml
!include templates/plantuml-theme.puml

scale 2/3
left to right direction
center header
    C4 Architecture: Foundry Local with Phi-4
endheader

!include templates/c4/C4_Container.puml

title AI Scenario 2: Foundry Local using local Phi-4 model

Person(user, "Church Staff", "Uses local assistant for private analysis")

System_Boundary(system, "Church Bulletin") {
    Container(chatClient, "Chat Client", "Blazor WebAssembly", "Conversational assistant UI")
    Container(api, "UI Server API", "ASP.NET", "Coordinates prompt flow and authorization")
    Container(llmGateway, "LlmGateway", "Microsoft.Extensions.AI", "Targets local Foundry endpoint")
    Container(localFoundry, "Foundry Local Runtime", "Local AI runtime", "Hosts Phi-4 model on-premises")
}

System_Ext(phi4Model, "Phi-4 Model", "Local model weights")
System_Ext(dataStore, "Work Order Database", "SQL Server")

Rel(user, chatClient, "Chats with assistant", "HTTPS")
Rel(chatClient, api, "Sends prompts", "HTTPS")
Rel(api, llmGateway, "Builds AI requests", "In-process")
Rel(llmGateway, localFoundry, "Calls local chat endpoint", "HTTP")
Rel(localFoundry, phi4Model, "Loads and executes model", "Local filesystem / GPU")
Rel(api, dataStore, "Reads work orders for context", "EF Core / TCP")

LEGEND("Legend","Chat Client: Blazor WASM UI\nUI Server API: ASP.NET endpoints\nLlmGateway: AI adapter\nFoundry Local Runtime: local model serving\nPhi-4 Model: local model artifact")
FOOTER()
@enduml
