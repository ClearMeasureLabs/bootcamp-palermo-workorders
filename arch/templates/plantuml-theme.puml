' PlantUML theme and helpers for architecture diagrams
' Usage: include with: !include templates/plantuml-theme.puml (or use the raw GitHub URL when rendering in CI)

' Diagram version, update as needed by maintainers
!define DIAGRAM_VERSION v1.0

' Basic visual settings
' Choose fonts (fallback order)
skinparam defaultFontName "Segoe UI, Arial, DejaVu Sans, sans-serif"
skinparam titleFontName "Segoe UI, Arial, DejaVu Sans, sans-serif"
skinparam shadowing false
skinparam dpi 150

' Title and header sizing
skinparam titleFontSize 18
skinparam headerFontSize 14

' Palette (brand-friendly, friendly teal / indigo accents)
!define COLOR_BG #FFFFFF
!define COLOR_PRIMARY #0F766E
!define COLOR_ACCENT #2C3E50
!define COLOR_MUTED #6B7280
!define COLOR_NOTE_BG #FFFBEB
!define COLOR_NOTE_BORDER #F59E0B

' Class / component colors
skinparam classBackgroundColor COLOR_BG
skinparam classBorderColor COLOR_PRIMARY
skinparam componentBackgroundColor #F7FEFD
skinparam componentBorderColor COLOR_PRIMARY
skinparam sequenceBackgroundColor COLOR_BG
skinparam sequenceLifeLineBorderColor COLOR_PRIMARY

' Notes & legend styling
skinparam noteBackgroundColor COLOR_NOTE_BG
skinparam noteBorderColor COLOR_NOTE_BORDER
skinparam legendBackgroundColor COLOR_BG
skinparam legendBorderColor COLOR_PRIMARY

' Box styling for containers and components
skinparam rectangle {
  BackgroundColor COLOR_BG
  BorderColor COLOR_PRIMARY
}

' Small helper to show a consistent footer
!definelong FOOTER()
center footer
    Diagram version: DIAGRAM_VERSION
endfooter
!enddefinelong

' Helper to render a legend box
!definelong LEGEND(title, content)
legend
|= title |= description |
| Legend | {note: content} |
endlegend
!enddefinelong

' Helper: render a callout note style
!definelong CALLOUT(text)
note right
  text
end note
!enddefinelong

' Note: when included in a PlantUML file the macros FOOTER() and LEGEND() can be invoked where appropriate.
