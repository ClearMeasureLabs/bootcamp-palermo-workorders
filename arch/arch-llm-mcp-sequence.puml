@startuml
!includeurl https://raw.githubusercontent.com/ClearMeasureLabs/bootcamp-palermo-workorders/docs/architecture-enhancements/arch/templates/plantuml-theme.puml

title LLM / MCP End-to-End Sequence (Assign-to-Bot)

actor "User" as user
participant "Blazor WASM Client" as ui
participant "SingleApiController\n(UI.Server)" as api
participant "Bus : IBus" as sBus
participant "IMediator" as mediator
participant "StateCommandHandler" as cmdHandler
participant "DraftToAssignedCommand" as cmd
participant "StateCommandBase" as cmdBase
participant "WorkOrder" as order
database "DataContext\n(EF Core)" as db
participant "DistributedBus\n: IDistributedBus" as dBus
participant "NServiceBus" as nsb
participant "Worker Service" as worker
participant "LlmGateway" as llm
participant "Azure OpenAI" as azure

autonumber

user -> ui : Assign work order to assignee (UI)
ui -> api : POST WebServiceMessage\n(DraftToAssignedCommand)
api -> api : Deserialize\nWebServiceMessage.GetBodyObject()
api -> sBus : Send(DraftToAssignedCommand)
sBus -> mediator : Send(DraftToAssignedCommand)
mediator -> cmdHandler : Handle(DraftToAssignedCommand,\nCancellationToken)
cmdHandler -> cmd : Execute(StateCommandContext\n{ CurrentDateTime = UtcNow })
cmd -> order : AssignedDate = CurrentDateTime
cmd -> cmdBase : base.Execute(context)
cmdBase -> order : ChangeStatus(CurrentUser,\nCurrentDateTime, Assigned)

alt Assignee has Bot role
    cmd -> cmd : Create WorkOrderAssignedToBotEvent
end

cmdHandler -> db : Attach/Add or Update(order)
cmdHandler -> db : SaveChangesAsync()
db --> cmdHandler : persisted
cmdHandler -> cmdHandler : Build debug message
cmdHandler -> dBus : PublishAsync(StateTransitionEvent)

alt WorkOrderAssignedToBotEvent exists
    dBus -> nsb : Publish(WorkOrderAssignedToBotEvent)
    nsb -> worker : Deliver(WorkOrderAssignedToBotEvent)
    worker -> worker : Handle(WorkOrderAssignedToBotEvent)
    worker -> llm : Prepare prompt / context (WorkOrder details)
    llm -> azure : Call LLM API (model, prompt)
    azure --> llm : LLM response (text, metadata)
    worker -> db : Attach / update WorkOrder with LLM output
    worker -> db : SaveChangesAsync()
    db --> worker : persisted
    worker -> dBus : PublishAsync(WorkOrderBotCompletedEvent)
    note right of worker : Optionally notify UI or send email
end

cmdHandler --> mediator : StateCommandResult\n(order, "Assign", debugMessage)
mediator --> sBus : StateCommandResult
sBus --> api : StateCommandResult
api --> ui : WebServiceMessage\n(serialized result)

LEGEND("Legend","Bus: IBus (local mediator bus)\nDistributedBus: IDistributedBus publishes domain events\nNServiceBus: external transport for long-running processing\nLLM: Azure OpenAI calls\nWorker: background service that handles bot events")
FOOTER()
@enduml
